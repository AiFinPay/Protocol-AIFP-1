#!/bin/sh
# Pre-push hook: scan the push for secrets before any refs leave the local repo.
# Install with: chmod +x .git/hooks/pre-push

set -eu

if ! command -v gitleaks >/dev/null 2>&1; then
    echo "gitleaks not found in PATH; skipping pre-push secret scan."
    echo "Install gitleaks to enforce this check: https://github.com/gitleaks/gitleaks"
    exit 0
fi

# gitleaks protect scans unstaged/staged changes and the range being pushed.
echo "Running gitleaks protect..."
gitleaks protect --staged --verbose --redact --no-git
