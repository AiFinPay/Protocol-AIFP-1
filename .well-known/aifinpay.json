{
  "name": "AiFinPay Paywall",
  "version": "1.0",
  "protocol": "aifinpay",
  "default_environment": "sandbox",
  "base_urls": {
    "sandbox": "https://sandbox.api.aifinpay.io",
    "production": "https://api.aifinpay.io"
  },
  "confirmation_required": {
    "create_wallet": true,
    "fund_wallet": true,
    "authorize_spend": true,
    "promote_to_production": true
  },
  "consent": {
    "human_required_before_spend": true,
    "human_required_before_wallet_creation": true,
    "human_required_before_funding": true
  },
  "surfaces": {
    "human_docs": [
      "/docs/index.md",
      "/docs/quickstart/index.md",
      "/docs/core-concepts/index.md",
      "/docs/reference/index.md"
    ],
    "mcp": {
      "package": "@aifinpay/mcp",
      "purpose": "Connect a developer tool or agent runtime to the protocol through a sanctioned MCP server"
    }
  },
  "sdk_packages": {
    "agent": [
      "@aifinpay/agent@alpha",
      "aifinpay-agent@alpha"
    ],
    "merchant": [
      "@aifinpay/merchant@alpha",
      "aifinpay-merchant@alpha"
    ],
    "mcp": [
      "@aifinpay/mcp@alpha"
    ]
  },
  "payment_policy": {
    "sandbox_first": true,
    "production_requires_review": true,
    "wallet_creation_requires_review": true
  },
  "notes": [
    "This manifest is machine-readable and intentionally declarative.",
    "Human-readable onboarding lives in docs/.",
    "Any money-moving or wallet-creating action requires explicit human confirmation."
  ]
}
